---
# Porth-IO: Immaculate Engineering Linter Configuration
# Catches code-smells and ensures C++23/HFT best practices.
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  portability-*,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -readability-identifier-length

# Treat all warnings as errors to bridge the "Trust Gap"
WarningsAsErrors: "*"

CheckOptions:
  # Ensure we use modern C++23 trailing return types where it adds clarity
  - key:             modernize-use-trailing-return-type.MinArity
    value:           '2'
  # Limit complexity to ensure deterministic execution paths
  - key:             readability-function-cognitive-complexity.Threshold
    value:           '12'
  # Enforce professional naming conventions for the Newport cluster
  - key:             readability-identifier-naming.ClassCase
    value:           'CamelCase'
  - key:             readability-identifier-naming.FunctionCase
    value:           'lower_case'
  - key:             readability-identifier-naming.MemberCase
    value:           'lower_case'
  # Differentiate between public members and private/protected members
  - key:             readability-identifier-naming.PublicMemberCase
    value:           'lower_case'
  - key:             readability-identifier-naming.PrivateMemberPrefix
    value:           'm_'
  - key:             readability-identifier-naming.PrivateMemberCase
    value:           'lower_case'
  - key:             readability-identifier-naming.ProtectedMemberPrefix
    value:           'm_'
  - key:             readability-identifier-naming.ProtectedMemberCase
    value:           'lower_case'